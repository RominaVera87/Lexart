@using global::Assets.ApiClient.Generated
@using MudBlazor

<MudDialog>

    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" />
            <MudText Typo="Typo.h6">Asset Details</MudText>
        </MudStack>
    </TitleContent>

    <DialogContent>

        @if (AssetModel is null)
        {
            <MudText>No data.</MudText>
        }
        else
        {
            <MudStack Spacing="2">

                <MudGrid>

                    <MudItem xs="1">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" />
                    </MudItem>

                    <MudItem xs="3">
                        <MudText>Name:</MudText>
                    </MudItem>

                    <MudItem xs="8">
                        <MudText>@AssetModel.Name</MudText>
                    </MudItem>

                </MudGrid>


                <MudGrid>

                    <MudItem xs="1">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Color="Color.Primary" />
                    </MudItem>

                    <MudItem xs="3">
                        <MudText>Type:</MudText>
                    </MudItem>

                    <MudItem xs="8">
                        <MudText>@AssetModel.Type</MudText>
                    </MudItem>

                </MudGrid>


                <MudGrid>

                    <MudItem xs="1">
                        <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Color="Color.Primary" />
                    </MudItem>

                    <MudItem xs="3">
                        <MudText>Id:</MudText>
                    </MudItem>

                    <MudItem xs="8">
                        <MudText Style="word-break:break-all">
                            @AssetModel.Id
                        </MudText>
                    </MudItem>

                </MudGrid>

            </MudStack>
        }

    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">
            Close
        </MudButton>
    </DialogActions>

</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Asset? AssetModel { get; set; }

    private void Close() => MudDialog.Close();
}