@using MudBlazor
@using global::Assets.ApiClient.Generated
@inject IAssetsApiClient AssetService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        @(IsEdit ? "Modify Telemetry Log" : "Create Telemetry Log")
    </TitleContent>

    <DialogContent>

        <MudText Typo="Typo.h6" Class="mb-2">
            @(IsEdit ? "Edit telemetry log" : "New telemetry log")
        </MudText>

        <MudDatePicker Label="Timestamp (date)"
                       @bind-Date="_date"
                       Required="true" />

        <MudTimePicker Label="Timestamp (time)"
                       @bind-Time="_time"
                       Required="true" />

        <MudNumericField T="int"
                         Label="Health score"
                         @bind-Value="healthScore"
                         Min="0"
                         Max="100"
                         Required="true" />

    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>

        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">
            @(IsEdit ? "Modify" : "Create")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }

    [Parameter] public Guid AssetId { get; set; }
    [Parameter] public TelemetryLog? LogModel { get; set; }
    [Parameter] public bool IsEdit { get; set; }

    private DateTime? _date;
    private TimeSpan? _time;
    private int healthScore = 0;

    protected override void OnInitialized()
    {
        if (LogModel is not null)
        {
            _date = LogModel.Timestamp.LocalDateTime.Date;
            _time = LogModel.Timestamp.LocalDateTime.TimeOfDay;
            healthScore = LogModel.HealthScore;
        }
        else
        {
            var now = DateTime.Now;
            _date = now.Date;
            _time = now.TimeOfDay;
        }
    }

    private async Task Save()
    {
        if (_date is null || _time is null)
        {
            Snackbar.Add("Timestamp is required.", Severity.Error);
            return;
        }

        var ts = new DateTime(_date.Value.Year, _date.Value.Month, _date.Value.Day,
                              _time.Value.Hours, _time.Value.Minutes, _time.Value.Seconds,
                              DateTimeKind.Local);

        var dtoTimestamp = new DateTimeOffset(ts);

        try
        {
            if (IsEdit)
            {
                if (LogModel is null)
                {
                    Snackbar.Add("Missing telemetry log.", Severity.Error);
                    return;
                }

                var req = new TelemetryLogUpdateRequest
                {
                    Timestamp = dtoTimestamp,
                    HealthScore = healthScore
                };

                await AssetService.UpdateTelemetryLogAsync(req, AssetId, LogModel.Id);
                Snackbar.Add("Telemetry log modified.", Severity.Success);
            }
            else
            {
                var req = new TelemetryLogCreateRequest
                {
                    Timestamp = dtoTimestamp,
                    HealthScore = healthScore
                };

                await AssetService.CreateTelemetryLogAsync(req, AssetId, null, null);
                Snackbar.Add("Telemetry log created.", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Operation failed: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();
}