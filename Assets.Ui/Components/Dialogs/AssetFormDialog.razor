@using MudBlazor
@using global::Assets.ApiClient.Generated
@inject IAssetsApiClient AssetService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        Create New Asset
    </TitleContent>

    <DialogContent>

        <MudText Typo="Typo.h6" Class="mb-2">New Asset</MudText>

        <MudTextField Label="Name" @bind-Value="model.Name" Required="true" />
        <MudTextField Label="Type" @bind-Value="model.Type" Required="true" />

    </DialogContent>

    <DialogActions>

        <MudButton OnClick="Cancel">Cancel</MudButton>

        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">
            @(IsEdit ? "Modify" : "Create")
        </MudButton>

    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public Asset AssetModel { get; set; }

    [Parameter]
    public bool IsEdit { get; set; }


    protected override void OnInitialized()
    {
        if (AssetModel != null)
            model = new Asset
            {
                Id = AssetModel.Id,
                Name = AssetModel.Name,
                Type = AssetModel.Type
            };
    }

    private Asset model = new();

    private async Task Save()
    {
        try
        {
            if (IsEdit)
            {
                AssetUpdateRequest updateRequest = new()
                {
                    Name = model.Name,
                    Type = model.Type
                };

                await AssetService.UpdateAssetAsync(updateRequest, model.Id);
                Snackbar.Add("Asset modified.", Severity.Success);
            }
            else
            {
                AssetCreateRequest assetCreateRequest = new()
                {
                    Name = model.Name,
                    Type = model.Type
                };

                await AssetService.CreateAssetAsync(assetCreateRequest);
                Snackbar.Add("Asset created.", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Operation failed: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

}