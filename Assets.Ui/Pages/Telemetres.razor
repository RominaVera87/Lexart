@page "/assets/{AssetId:guid}/telemetry"
@using global::Assets.ApiClient.Generated
@using global::Assets.Ui.Components.Dialogs
@using MudBlazor
@inject IAssetsApiClient AssetService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudPaper Class="mx-auto my-6 pa-4" Style="max-width:1000px;min-height:calc(90vh - 150px);">

    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h4">Telemetry Logs</MudText>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Title="Create telemetry log"
                   Style="border-radius:999px;color:white"
                   OnClick="CreateTelemetryLog">
            Add
        </MudButton>
    </MudStack>

    <MudTable Items="logs ?? Array.Empty<TelemetryLog>()"
              Hover="true"
              Dense="true"
              SortLabel="Sort by"
              FixedHeader="true"
              Height="calc(100vh - 220px)">

        <HeaderContent>

            <MudTh Style="font-weight:600;opacity:0.9">
                <MudTableSortLabel InitialDirection="SortDirection.Descending"
                                   SortBy="new Func<TelemetryLog, object>(x => x.Timestamp)">
                    Timestamp
                </MudTableSortLabel>
            </MudTh>

            <MudTh Style="font-weight:600;opacity:0.9">
                <MudTableSortLabel SortBy="new Func<TelemetryLog, object>(x => x.HealthScore)">
                    Health Score
                </MudTableSortLabel>
            </MudTh>

            <MudTh Align="Align.Right" Style="font-weight:600;opacity:0.9;width:120px">
                Actions
            </MudTh>

        </HeaderContent>

        <RowTemplate>

            <MudTd DataLabel="Timestamp">@context.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd DataLabel="Health Score">@context.HealthScore</MudTd>

            <MudTd Align="Align.Right" Style="white-space:nowrap;width:120px">
                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">

                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Title="Edit"
                                   OnClick="@(() => EditTelemetryLog(context.Id))" />

                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Title="Delete"
                                   Disabled="@isDeleting"
                                   OnClick="@(() => DeleteTelemetryLog(context.Id))" />

                </MudStack>
            </MudTd>

        </RowTemplate>

        <NoRecordsContent>
            @if (logs is null)
            {
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-6">
                    <MudProgressCircular Indeterminate="true" />
                    <MudText Class="mt-2">Loading...</MudText>
                </MudStack>
            }
            else
            {
                <MudText Class="py-6">No telemetry logs found.</MudText>
            }
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
        </PagerContent>

    </MudTable>

</MudPaper>

@code {
    [Parameter]
    public Guid AssetId { get; set; }

    private ICollection<TelemetryLog>? logs;
    private bool isDeleting;

    protected override async Task OnParametersSetAsync()
    {
        logs = await AssetService.ListTelemetryLogsAsync(AssetId, null, null);
    }

    private async Task ReloadAsync()
    {
        logs = await AssetService.ListTelemetryLogsAsync(AssetId, null, null);
        StateHasChanged();
    }

    private async Task CreateTelemetryLog()
    {
        var parameters = new DialogParameters
        {
            { "AssetId", AssetId },
            { "IsEdit", false }
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<TelemetryLogFormDialog>("Create Telemetry Log", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
            await ReloadAsync();
    }

    private async Task EditTelemetryLog(Guid logId)
    {
        var log = logs?.FirstOrDefault(x => x.Id == logId);
        if (log is null) return;

        var parameters = new DialogParameters
        {
            { "AssetId", AssetId },
            { "LogModel", log },
            { "IsEdit", true }
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<TelemetryLogFormDialog>("Modify Telemetry Log", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
            await ReloadAsync();
    }

    private async Task DeleteTelemetryLog(Guid logId)
    {
        var parameters = new DialogParameters
        {
            { "ContentText", "Are you sure you want to delete this telemetry log?" },
            { "ButtonText", "Delete" },
            { "Color", Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Telemetry Log", parameters);
        var result = await dialog.Result;

        if (result.Canceled) return;

        try
        {
            isDeleting = true;

            await AssetService.DeleteTelemetryLogAsync(AssetId, logId);

            var removed = logs?.FirstOrDefault(x => x.Id == logId);
            if (removed is not null)
                logs!.Remove(removed);

            Snackbar.Add("Telemetry log deleted.", Severity.Success);
        }
        catch (ApiException apiEx)
        {
            // NSwag strict client: if API returns 200 but spec expects 204
            if (apiEx.StatusCode == 200)
            {
                var removed = logs?.FirstOrDefault(x => x.Id == logId);
                if (removed is not null)
                    logs!.Remove(removed);

                Snackbar.Add("Telemetry log deleted.", Severity.Success);
                return;
            }

            Snackbar.Add($"Failed to delete telemetry log: {apiEx.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete telemetry log: {ex.Message}", Severity.Error);
        }
        finally
        {
            isDeleting = false;
        }
    }
}